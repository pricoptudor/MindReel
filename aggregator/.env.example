# MindReel Aggregator Environment
# Copy to .env and fill in your values

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
TARGET_USER_ID=your-auth-user-uuid

# YouTube Data API v3 (optional, get at https://console.cloud.google.com)
YOUTUBE_API_KEY=

# Reddit API (optional, create app at https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# OpenAI (optional, for AI-powered classification)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
